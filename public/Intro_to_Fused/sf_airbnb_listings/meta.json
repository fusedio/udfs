{
  "version": "0.0.3",
  "job_config": {
    "version": "0.0.3",
    "name": null,
    "steps": [
      {
        "type": "udf",
        "udf": {
          "type": "geopandas_v2",
          "name": "sf_airbnb_listings",
          "entrypoint": "udf",
          "parameters": {},
          "metadata": {
            "fused:name": "sf_airbnb_listings",
            "fused:slug": "sf_airbnb_listings",
            "fused:vizConfig": {
              "tileLayer": {
                "@@type": "TileLayer",
                "minZoom": 0,
                "maxZoom": 19,
                "tileSize": 256
              },
              "rasterLayer": {
                "@@type": "BitmapLayer",
                "pickable": true
              },
              "vectorLayer": {
                "@@type": "GeoJsonLayer",
                "stroked": true,
                "filled": false,
                "pickable": true,
                "lineWidthMinPixels": 1,
                "pointRadiusMinPixels": 1,
                "getLineColor": {
                  "@@function": "colorContinuous",
                  "attr": "value",
                  "domain": [
                    0,
                    10
                  ],
                  "steps": 20,
                  "colors": "Sunset",
                  "nullColor": [
                    184,
                    184,
                    184
                  ]
                },
                "getFillColor": [
                  208,
                  208,
                  208,
                  40
                ]
              },
              "hexLayer": {
                "@@type": "H3HexagonLayer",
                "stroked": true,
                "filled": true,
                "pickable": true,
                "extruded": false,
                "opacity": 1,
                "coverage": 0.9,
                "lineWidthMinPixels": 1,
                "getHexagon": "@@=properties.hex",
                "getLineColor": {
                  "@@function": "colorContinuous",
                  "attr": "value",
                  "domain": [
                    0,
                    10
                  ],
                  "steps": 20,
                  "colors": "Sunset",
                  "nullColor": [
                    184,
                    184,
                    184
                  ]
                },
                "getFillColor": {
                  "@@function": "colorContinuous",
                  "attr": "value",
                  "domain": [
                    0,
                    10
                  ],
                  "steps": 20,
                  "colors": "Sunset",
                  "nullColor": [
                    184,
                    184,
                    184
                  ]
                },
                "getElevation": {
                  "@@function": "hasProp",
                  "property": "value",
                  "present": "@@=properties.value",
                  "absent": 1
                },
                "elevationScale": 10
              }
            },
            "fused:udfType": "auto"
          },
          "code": "@fused.udf\ndef udf(path: str = \"s3://fused-sample/demo_data/airbnb_listings_sf.parquet\"):\n    import pandas as pd\n    df = pd.read_parquet(path)\n    \n    # Remove .head(100) & press \"Shift + Enter\" to run\n    return df.head(100)\n",
          "headers": []
        }
      }
    ],
    "metadata": null
  }
}