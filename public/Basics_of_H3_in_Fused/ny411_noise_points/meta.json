                "@@type": "TileLayer",
                "minZoom": 0,
                "maxZoom": 19,
                "tileSize": 256,
                "pickable": true
              },
              "hexLayer": {
                "@@type": "H3HexagonLayer",
                "stroked": false,
                "filled": true,
                "pickable": true,
                "extruded": false,
                "opacity": 1,
                "coverage": 0.9,
                "lineWidthMinPixels": 10,
