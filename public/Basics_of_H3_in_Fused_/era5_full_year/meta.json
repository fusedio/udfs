            "fused:name": "era5_full_year",
            "fused:slug": "era5_full_year",
            "fused:vizConfig": {
              "tileLayer": {
                "@@type": "TileLayer",
                "minZoom": 0,
                "maxZoom": 19,
                "tileSize": 256
              },
              "rasterLayer": {
                "@@type": "BitmapLayer",
                "pickable": true
